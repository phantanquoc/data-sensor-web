      // Seed startMs từ DB document cho giai đoạn gNum
      function seedStartMsFromDoc(gNum) {
        if (!currentRunningDoc) return Date.now();
        var gdKey = 'giai_doan_' + gNum;
        var gd = currentRunningDoc[gdKey];
        if (!gd || !Array.isArray(gd.bien_du_lieu) || gd.bien_du_lieu.length < 2) return Date.now();
        var first = gd.bien_du_lieu[1]; // dòng [0] là bản ghi khởi tạo (thoi_gian rỗng), thực bắt đầu từ [1]
        var last = gd.bien_du_lieu[gd.bien_du_lieu.length - 1];
        var tsFirst = parseTs(first.thoi_gian);
        var tsLast = parseTs(last.thoi_gian);
        if (!tsFirst || !tsLast) return Date.now();
        var elapsedAtSeed = tsLast.getTime() - tsFirst.getTime();
        if (elapsedAtSeed < 0) elapsedAtSeed = 0;
        return Date.now() - elapsedAtSeed;
      }
