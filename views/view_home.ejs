      // Parse chuỗi "HH:MM:SS DD/MM/YYYY" -> Date, trả null nếu không hợp lệ
      function parseTs(str) {
        if (!str || typeof str !== 'string' || str.trim() === '') return null;
        var parts = str.trim().split(' ');
        if (parts.length < 2) return null;
        var timeParts = parts[0].split(':');
        var dateParts = parts[1].split('/');
        if (timeParts.length < 3 || dateParts.length < 3) return null;
        var h = parseInt(timeParts[0], 10);
        var m = parseInt(timeParts[1], 10);
        var s = parseInt(timeParts[2], 10);
        var d = parseInt(dateParts[0], 10);
        var mo = parseInt(dateParts[1], 10);
        var y = parseInt(dateParts[2], 10);
        if (isNaN(h) || isNaN(m) || isNaN(s) || isNaN(d) || isNaN(mo) || isNaN(y)) return null;
        return new Date(y, mo - 1, d, h, m, s);
      }

      // Render SVG donut vào selector cho giai đoạn stageNum
      function renderDonut(stageNum) {
        var el = document.querySelector('.active_gia_doan_' + stageNum);
        if (!el) return;
        if (stageTimer.stage !== stageNum) { el.innerHTML = ''; return; }
        var elapsedMs = Date.now() - stageTimer.startMs;
        var elapsedMin = elapsedMs / 60000;
        var targetMin = stageTimer.targetMin;
        var pct = 0;
        var color = '#00aaff';
        var targetText = '--';
        if (targetMin > 0) {
          pct = Math.min((elapsedMin / targetMin) * 100, 100);
          targetText = String(Math.round(targetMin));
          if (elapsedMin > targetMin) { color = '#fd7e14'; }
        }
        var elapsedText = elapsedMin.toFixed(1);
        // SVG donut: radius=27, circumference=2*pi*27=169.646
        var circ = 169.646;
        var dashOffset = circ - (circ * pct / 100);
        var strokeBg = '#e0e0e0';
        el.innerHTML = '<div style="display:flex;justify-content:center;align-items:center;height:70px;">' +
          '<svg width="70" height="70" viewBox="0 0 70 70">' +
            '<circle cx="35" cy="35" r="27" fill="none" stroke="' + strokeBg + '" stroke-width="5"/>' +
            (targetMin > 0 ? '<circle cx="35" cy="35" r="27" fill="none" stroke="' + color + '" stroke-width="5" ' +
              'stroke-dasharray="' + circ.toFixed(3) + '" stroke-dashoffset="' + dashOffset.toFixed(3) + '" ' +
              'stroke-linecap="round" transform="rotate(-90 35 35)" style="transition:stroke-dashoffset 0.3s;"/>' : '') +
            '<text x="35" y="33" text-anchor="middle" font-size="9" fill="#333" font-weight="bold">' +
              elapsedText + ' / ' + targetText +
            '</text>' +
            '<text x="35" y="44" text-anchor="middle" font-size="8" fill="#666">phút</text>' +
          '</svg>' +
        '</div>';
      }

      // Bắt đầu interval 1s cho donut (chỉ tạo 1 interval duy nhất)
      function startDonutInterval() {
        if (donutIntervalId != null) return; // đã chạy rồi
        donutIntervalId = setInterval(function() {
          if (stageTimer.stage != null) {
            renderDonut(stageTimer.stage);
          }
        }, 1000);
      }

      // Dừng interval donut
      function stopDonutInterval() {
        if (donutIntervalId != null) {
          clearInterval(donutIntervalId);
          donutIntervalId = null;
        }
      }

      // Reset toàn bộ donut timer state
      function resetDonutState() {
        stageTimer.stage = null;
        stageTimer.startMs = 0;
        stageTimer.targetMin = 0;
        stopDonutInterval();
        for (var i = 1; i <= 4; i++) {
