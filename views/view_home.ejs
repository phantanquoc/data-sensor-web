      // (không chờ socket). Dựng lại payload dạng socket từ document DB.
      function auto_load_noi_chien(n) {
        const soN = String(n);
        fetch(`/get_noi_chien?so_noiChien=${Number(n)}`)
          .then((res) => res.json())
          .then((documents) => {
            if (!Array.isArray(documents)) return;
            // 1) Nạp danh sách mẻ chiên vào bảng (list nhẹ, chỉ có _id/thoi_gian_start/thoi_gian_stop/dong_ep_khoi_dong)
            loadDocuments(documents);
            if (documents.length === 0) {
              // Không có mẻ nào → giữ trạng thái reset (0)
              reset_realTimer_he_chien(soN, data_reset);
              return;
            }
            // 2) Chọn mẻ đang chạy MỚI NHẤT (duyệt ngược), nếu không có thì lấy mẻ mới nhất
            var running = null;
            for (var i = documents.length - 1; i >= 0; i--) {
              if (documents[i].thoi_gian_stop === "" || documents[i].thoi_gian_stop == null) {
                running = documents[i];
                break;
              }
            }
            const chosen = running || documents[documents.length - 1];
            // 3) Fetch full document của mẻ được chọn để dựng realtime
            fetch(`/get_noi_chien_detail?id=${chosen._id}&so_noiChien=${Number(n)}`)
              .then((res2) => res2.json())
              .then((fullDoc) => {
                // Lưu doc đang chạy để seed startMs cho donut khi socket tick đầu tiên đến
                currentRunningDoc = running ? fullDoc : null;

                const ZERO = {
                  ap_suat_vo_hoi: 0,
                  ap_suat_chan_khong: 0,
                  ap_suat_vong_nuoc: 0,
                  nhiet_do: 0,
                  dong_dien_dong_co_root: 0,
                  dong_dien_dong_co_vong_nuoc: 0,
                  nhiet_do_vao_binh_sinh_han: 0,
                  nhiet_do_ra_binh_sinh_han: 0,
                  nhiet_do_vao_bom_vong_nuoc: 0,
                  nhiet_do_ra_bom_vong_nuoc: 0,
                };
                const lastOf = (gd) =>
                  gd && Array.isArray(gd.bien_du_lieu) && gd.bien_du_lieu.length
                    ? gd.bien_du_lieu[gd.bien_du_lieu.length - 1]
                    : ZERO;

                // 4) Dựng lại 4 payload giai đoạn (thứ tự 1→4 giống backend emit)
                for (let g = 1; g <= 3; g++) {
                  const gd = fullDoc["giai_doan_" + g] || {};
                  realTimer_he_chien(soN, {
                    data: lastOf(gd),
                    giai_doan: "Giai đoạn: " + g,
                    active: false,
                    tong_thoi_gian_chay: fullDoc.tong_thoi_gian_chay,
                    set_giai_doan: {
                      thoi_gian_chay: gd.thoi_gian_chay,
