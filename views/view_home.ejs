    <title>Dashboard PLC</title>
    <script src="/js/socket.io.js"></script>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
      }

      .header {
        display: flex;
        background: #333;
        overflow-x: auto;
        position: sticky;
        top: 0;
      }

      .header button {
        min-width: 120px;
        padding: 15px;
        border: none;
        background: #333;
        color: #fff;
        cursor: pointer;
      }

      .header button.active {
        background: #2196f3;
      }

      body {
        font-family: Arial, sans-serif;
        background: #f2f4f7;
        margin: 0;
        padding: 20px;
      }

      h1 {
        /* text-align: center; */
        padding-bottom: 20px;
      }

      .time-box {
        background: white;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
      }

      .stage {
        background: white;
        margin-bottom: 20px;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
      }

      .stage h2 {
        margin-top: 0;
        color: #1976d2;
        padding-bottom: 20px;
      }

      .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 10px;
        margin-bottom: 20px;
      }

      .info-item {
        background: #eef5ff;
        padding: 10px;
        border-radius: 8px;
      }

      .table {
        width: 100%;
        max-height: 500px;
        border-collapse: collapse;
        overflow-x: auto;
        display: block;
      }

      th,
      td {
        border: 1px solid #ccc;
        padding: 8px;
        text-align: center;
        white-space: nowrap;
      }

      th {
        background: #1976d2;
        color: white;
        position: sticky;
        top: 0; /* dính vào đỉnh vùng scroll */
        z-index: 10; /* tránh bị td đè lên */
      }
      .hover:hover {
        background: #1976d2;
      }
    </style>
